#!/bin/sh
# VNC session entrypoint — launches the Xfce desktop for the noVNC chain.
# Invoked by tigervncserver for display :1 (see openclaw-desktop-vnc.service).
# Kept minimal on purpose: attendees may open it.

unset SESSION_MANAGER
unset DBUS_SESSION_BUS_ADDRESS

[ -r "$HOME/.Xresources" ] && xrdb "$HOME/.Xresources"

# vncconfig runs headlessly and bridges the VNC clipboard with the noVNC
# browser clipboard panel (the arrow tab on the left side of the noVNC UI).
# Must start before the session so it can register with the X server.
vncconfig -nowin &

# Disable screensaver and lock screen — the desktop is behind nginx basic-auth
# over a Cloudflare Tunnel; an Xfce lock screen is redundant and a dead-end
# (the ubuntu user has no OS password on cloud images).
xfconf-query -c xfce4-screensaver -p /screensaver/enabled -s false 2>/dev/null || true
xfconf-query -c xfce4-screensaver -p /lock/enabled -s false 2>/dev/null || true

# dbus-launch wires up the session bus Xfce needs for its panel/settings daemons.
exec dbus-launch --exit-with-session xfce4-session
