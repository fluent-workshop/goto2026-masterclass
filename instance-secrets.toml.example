# instance-secrets.toml.example — shape reference for the GOTO 2026 masterclass
#
# Copy this to instance-secrets.toml (gitignored) and fill in real values.
# The actual file must NEVER be committed — .gitignore blocks it.
#
# Two kinds of secrets live here:
#
#   PER-BOX (unique per instance):
#     CLOUDFLARED_TOKEN     — each box runs its own Cloudflare Tunnel connector;
#                             sharing a token would make all boxes HA replicas of
#                             one tunnel and break per-box hostname routing.
#     POSTGRES_APP_PASSWORD — unique DB password per box.
#     ANTHROPIC_API_KEY     — per-box Anthropic key for billing isolation
#                             (OpenClaw + Claude Code). Leave "" until issued.
#     OPENAI_API_KEY        — per-box OpenAI key for Codex CLI.
#                             Leave "" until issued. Can share fleet key if preferred.
#     DESKTOP_PASS          — the noVNC basic-auth password for this box's desktop,
#                             served at {box}-gt26-desktop-{hash8}.fluentworkshop.dev.
#                             Three-word hyphen-separated passphrase, unique per box.
#     DISCORD_APP_ID        — Discord application ID for this box's bot.
#     DISCORD_BOT_TOKEN     — Discord bot token for this box's bot.
#     SSH_IP                — Public IP of the GCP instance, for direct SSH access.
#                             Populated at provision time; leave "" until then.
#     OPENCLAW_GATEWAY_TOKEN — Pre-seeded auth token for the OpenClaw gateway.
#                             Generated with `openssl rand -hex 24`.
#
#   FLEET-WIDE (same value on every box — copy from one section to all others):
#     ELEVENLABS_API_KEY    — ElevenLabs account key for TTS skill.
#     EXA_API_KEY           — Exa search key for research skill.
#     FIRECRAWL_API_KEY     — Firecrawl key for web-scraping skill.
#     CODERABBIT_API_KEY    — CodeRabbit key for code-review skill.
#     VSCODE_TUNNEL_GITHUB_TOKEN
#                           — GitHub PAT (read:user scope) used to pre-authenticate
#                             VS Code Remote Tunnels at first boot. All boxes auth
#                             as the same class GitHub account; students access
#                             vscode.dev/tunnel/{hostname} using those credentials.
#
# Non-sensitive per-box config (ElevenLabs voice ID, role) lives in the
# git-tracked instances.toml instead. Secrets only here.
#
# clone.sh lookup order for DESKTOP_PASS:
#   1. This file (canonical)
#   2. infra/cloud-init/generated/credentials-manifest.tsv (legacy fallback)
#   3. Auto-generate + warn if absent from both

[pikachu]
CLOUDFLARED_TOKEN          = "eyJ..."              # from Cloudflare Zero Trust dashboard
POSTGRES_APP_PASSWORD      = "word-word-word"      # 3-word passphrase
ANTHROPIC_API_KEY          = ""                    # sk-ant-... (leave "" until issued)
OPENAI_API_KEY             = ""                    # sk-proj-... (leave "" until issued)
ELEVENLABS_API_KEY         = "sk_..."              # fleet-wide — copy to all boxes
EXA_API_KEY                = "..."                 # fleet-wide — copy to all boxes
FIRECRAWL_API_KEY          = "fc-..."              # fleet-wide — copy to all boxes
CODERABBIT_API_KEY         = "cr-..."              # fleet-wide — copy to all boxes
VSCODE_TUNNEL_GITHUB_TOKEN = "ghp_..."             # fleet-wide — copy to all boxes
DESKTOP_PASS               = "word-word-word"      # unique per box, shown on student card
DISCORD_APP_ID             = ""                    # from Discord Developer Portal
DISCORD_BOT_TOKEN          = ""                    # bot token from Developer Portal
SSH_IP                     = ""                    # GCP public IP, filled at provision time
OPENCLAW_GATEWAY_TOKEN     = ""                    # openssl rand -hex 24

[abra]
CLOUDFLARED_TOKEN          = "eyJ..."
POSTGRES_APP_PASSWORD      = "word-word-word"
ANTHROPIC_API_KEY          = ""
OPENAI_API_KEY             = ""
ELEVENLABS_API_KEY         = "sk_..."
EXA_API_KEY                = "..."
FIRECRAWL_API_KEY          = "fc-..."
CODERABBIT_API_KEY         = "cr-..."
VSCODE_TUNNEL_GITHUB_TOKEN = "ghp_..."
DESKTOP_PASS               = "word-word-word"
DISCORD_APP_ID             = ""
DISCORD_BOT_TOKEN          = ""
SSH_IP                     = ""
OPENCLAW_GATEWAY_TOKEN     = ""

# (repeat [section] block for each hostname in instances.toml)
# ditto, dragonite, gengar, jolteon, lapras, machamp, meowth,
# onix, rapidash, squirtle, vaporeon, vulpix
