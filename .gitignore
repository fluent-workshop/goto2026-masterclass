# Never commit secrets or generated artifacts
*.key
*.pem
*.env
.env*
secrets/
keys/
*.local
.DS_Store
# Generated per-instance cloud-init (contains injected keys)
infra/cloud-init/generated/
# cc-dispatch: track loop specs, ignore notify manifest + terraform state
.cc-dispatch/manifest.json
**/.terraform/*
*.tfstate
*.tfstate.*
.terraform.lock.hcl
crash.log

instance-secrets.toml

# Editor / sed -i.bak backup files — never commit
*.bak

# SonarQube scanner working directory
.scannerwork/

# cc-dispatch: reviews are ephemeral analysis artifacts
.cc-dispatch/reviews/

# cc-dispatch: per-turn heartbeat and compact files are ephemeral
.cc-dispatch/loops/*/progress.md
.cc-dispatch/loops/*/compact.md

# Scratch pad
.scratch/
